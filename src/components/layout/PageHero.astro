---
interface Props {
  title: string;
  subtitle?: string;
  image?: string;
}

const { title, subtitle, image } = Astro.props;
---

<section class="relative bg-surface-dark overflow-hidden">
  {image && (
    <img
      src={image}
      alt=""
      role="presentation"
      class="absolute inset-0 w-full h-full object-cover opacity-30"
    />
  )}
  <!-- Dégradé décoratif -->
  <div class="absolute inset-0 pointer-events-none page-hero-gradient"></div>

  <div class="relative max-w-site mx-auto px-4 md:px-8 py-20 md:py-28">
    {subtitle && (
      <p class="font-body text-xs text-secondary tracking-subtitle uppercase mb-4">
        {subtitle}
      </p>
    )}
    <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-light text-text-light leading-tight">
      {title}
    </h1>
    <div class="mt-6 w-16 h-px bg-secondary"></div>
  </div>
</section>

<style>
  .page-hero-gradient {
    background: radial-gradient(
      ellipse at 65% 50%,
      rgba(181, 135, 74, 0.10) 0%,
      transparent 70%
    );
  }
</style>
