---
import type { HistoireContent } from '../../../utils/i18n';

interface Props {
  content: HistoireContent;
}

const { content } = Astro.props;
---

<section class="bg-surface-alt py-20 md:py-28">
  <div class="max-w-site mx-auto px-4 md:px-8">

    <h2 class="fade-up font-display text-3xl md:text-4xl font-light text-primary mb-12">
      {content.timeline_title}
      <span class="block w-12 h-px bg-secondary mt-4"></span>
    </h2>

    <div class="relative flex flex-col gap-0">
      <!-- Ligne verticale -->
      <div class="absolute left-[3.25rem] top-0 bottom-0 w-px bg-border-rest hidden md:block" aria-hidden="true"></div>

      {content.timeline?.map((item, i) => (
        <div class="fade-up flex gap-8 md:gap-12 items-start py-8 border-b border-rest last:border-0"
             style={`transition-delay: ${i * 0.08}s`}>
          <!-- Année -->
          <div class="shrink-0 w-16 md:w-24">
            <span class="font-display text-xl md:text-2xl font-light text-secondary">{item.year}</span>
          </div>
          <!-- Contenu -->
          <div class="flex flex-col gap-2">
            <h3 class="font-display text-xl font-medium text-primary">{item.title}</h3>
            <p class="font-body text-sm text-muted leading-relaxed">{item.description}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script is:inline>
  (function () {
    const els = document.querySelectorAll('section .fade-up');
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1 });
    els.forEach(el => io.observe(el));
  })();
</script>
