---
import type { HomeContent } from '../../../utils/i18n';
import { getTranslator } from '../../../utils/i18n';

interface Props {
  content: HomeContent;
  locale: string;
}

const { content, locale } = Astro.props;
const t = await getTranslator(locale);
---

<section class="bg-surface-alt py-20 md:py-28">
  <div class="max-w-site mx-auto px-4 md:px-8">

    <h2 class="fade-up font-display text-3xl md:text-4xl font-light text-primary mb-12">
      {t('home.reviews_title')}
      <span class="block w-12 h-px bg-secondary mt-4"></span>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {content.reviews.map((review, i) => (
        <article
          class="fade-up bg-surface p-8 rounded-sm flex flex-col gap-4"
          style={`transition-delay: ${i * 0.1}s`}
        >
          <!-- Étoiles -->
          <div class="flex gap-1" aria-label={`${review.rating} étoiles sur 5`}>
            {Array.from({ length: 5 }).map((_, star) => (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
                class:list={['w-4 h-4', star < review.rating ? 'fill-secondary' : 'fill-border-rest']}
                aria-hidden="true"
              >
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Commentaire -->
          <p class="font-body text-sm text-primary leading-relaxed flex-1">
            "{review.comment}"
          </p>

          <!-- Auteur -->
          <div class="border-t border-rest pt-4 flex justify-between items-baseline">
            <span class="font-body text-sm font-medium text-primary">{review.author}</span>
            <span class="font-body text-xs text-muted">{review.date}</span>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<script is:inline>
  (function () {
    const els = document.querySelectorAll('section .fade-up');
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1 });
    els.forEach(el => io.observe(el));
  })();
</script>
