---
import type { HomeContent } from '../../../utils/i18n';
import { getTranslator } from '../../../utils/i18n';
import { netlifyImg } from '../../../utils/image';

interface Props {
  content: HomeContent;
  locale: string;
}

const { content, locale } = Astro.props;
const t = await getTranslator(locale);
---

<section class="bg-surface py-20 md:py-28">
  <div class="max-w-site mx-auto px-4 md:px-8">

    <h2 class="fade-up font-display text-3xl md:text-4xl font-light text-primary mb-12">
      {t('home.gallery_title')}
      <span class="block w-12 h-px bg-secondary mt-4"></span>
    </h2>

    <div class="gallery-grid grid grid-cols-2 md:grid-cols-4 auto-rows-[200px] gap-3">
      {content.gallery_images.map((img, i) => (
        <div
          class:list={[
            'fade-up overflow-hidden rounded-sm bg-surface-alt',
            img.variant === 'tall'  ? 'row-span-2'  : '',
            img.variant === 'wide'  ? 'col-span-2'  : '',
          ]}
          style={`transition-delay: ${i * 0.06}s`}
        >
          <img
            src={netlifyImg(img.src, 800)}
            alt={img.alt}
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
        </div>
      ))}
    </div>

  </div>
</section>

<script is:inline>
  (function () {
    const els = document.querySelectorAll('.gallery-grid .fade-up');
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.06 });
    els.forEach(el => io.observe(el));
  })();
</script>
